<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/meals_title"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.Calories.HomeCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/rowMealCircles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="horizontal">

                <include
                    android:id="@+id/mealBreakfast"
                    layout="@layout/item_home_meal_circle" />

                <include
                    android:id="@+id/mealLunch"
                    layout="@layout/item_home_meal_circle" />

                <include
                    android:id="@+id/mealDinner"
                    layout="@layout/item_home_meal_circle" />

                <include
                    android:id="@+id/mealSnacks"
                    layout="@layout/item_home_meal_circle" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnToggleMealDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingVertical="10dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/tvToggleMealDetails"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/view_meal_details"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivToggleMealDetails"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right_24"
                    app:tint="@color/primary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llMealDetailsDrawer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="4dp"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>