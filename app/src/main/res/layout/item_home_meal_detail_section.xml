<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvDetailMealTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Breakfast" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogFoodQuick"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="0dp"
            android:text="@string/log_food_quick"
            android:textColor="@color/primary"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llDetailFoods"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <TextView
        android:id="@+id/tvDetailEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/meal_empty_placeholder"
        android:textColor="@color/text_hint"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/llMacroPills"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="start"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvPillCarb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_macro_pill_carb"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="@color/white"
            android:textSize="11sp"
            tools:text="C 40g" />

        <TextView
            android:id="@+id/tvPillProtein"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_macro_pill_protein"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="@color/white"
            android:textSize="11sp"
            tools:text="P 25g" />

        <TextView
            android:id="@+id/tvPillFat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_macro_pill_fat"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="@color/white"
            android:textSize="11sp"
            tools:text="F 12g" />
    </LinearLayout>
</LinearLayout>
